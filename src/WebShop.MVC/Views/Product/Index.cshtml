@model IEnumerable<WebShop.MVC.ViewModels.ProductViewModel>

@{
    ViewData["Title"] = "Proizvodi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Proizvodi</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-custom-red">+ Dodaj proizvod</a>
    }
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 product-card shadow-sm">
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" class="card-img-top product-image" alt="@item.Name" />
                }
                else
                {
                    <div class="product-image d-flex align-items-center justify-content-center bg-light text-muted">
                        Nema slike
                    </div>
                }

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="text-muted mb-1">@item.CategoryName</p>
                    <p class="small mb-2">@item.Brand | @item.Sport | @item.Size</p>
                    <p class="card-text flex-grow-1">
                        @(string.IsNullOrWhiteSpace(item.Description) ? "Bez opisa." : item.Description)
                    </p>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="price-tag">@item.Price.ToString("N2") RSD</span>
                    </div>

                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Detalji</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Izmeni</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Obriši</a>
                        }

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline ms-auto">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Dodaj u korpu</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm ms-auto">
                                Uloguj se za korpu
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>