@model WebShop.MVC.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Brisanje korisnika";
}

<h1>Brisanje korisnika</h1>

<div class="alert alert-warning mt-3">
    Da li ste sigurni da želite da obrišete korisnika <strong>@Model.Username</strong>?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Korisničko ime:</strong> @Model.Username</p>
        <p><strong>Ime i prezime:</strong> @Model.FullName</p>
        <p><strong>Uloga:</strong> @Model.Role</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Odustani</a>
</form>